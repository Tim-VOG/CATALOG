# ──────────────────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard/project/<PROJECT>/settings/api
# ──────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ──────────────────────────────────────────────────────────
# Admin gate
# PIN asked when an admin enters /admin.
# Fallback is "1357" if left empty — change before going to prod.
# ──────────────────────────────────────────────────────────
VITE_ADMIN_PIN=1357

# ──────────────────────────────────────────────────────────
# Error monitoring (optional)
# Leave empty to disable Sentry in production.
# ──────────────────────────────────────────────────────────
VITE_SENTRY_DSN=

# ──────────────────────────────────────────────────────────
# Upload limits (bytes) — default 5 MB if unset
# ──────────────────────────────────────────────────────────
VITE_MAX_UPLOAD_SIZE=5242880

# ──────────────────────────────────────────────────────────
# API timeout (ms) — default 30000 if unset
# ──────────────────────────────────────────────────────────
VITE_API_TIMEOUT=30000
