{
  "rewrites": [
    { "source": "/((?!assets/|sw\\.js|manifest\\.webmanifest|icon-.*\\.svg|favicon\\.ico|robots\\.txt|.*\\.png|.*\\.jpg|.*\\.svg|.*\\.webmanifest).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
